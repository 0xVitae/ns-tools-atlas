# Neon Postgres Database
# ---------------------
# Connection string from Neon dashboard or Vercel Postgres integration
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Admin password for /pending page
ADMIN_PASSWORD=your-admin-password-here

# Admin token for URL-based auto-login (generate with: openssl rand -hex 32)
ADMIN_TOKEN=your-admin-token-here

# Telegram notifications for new submissions
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-telegram-chat-id
