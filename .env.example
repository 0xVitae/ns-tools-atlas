# ======================
# LOCAL DEVELOPMENT (recommended for contributors)
# ======================
# 1. Run: pnpm db:local        (starts Postgres + Neon proxy via Docker)
# 2. Run: pnpm db:push          (creates tables from schema)
# 3. Run: pnpm db:seed           (populates mock data)
# 4. Run: pnpm dev:vercel        (start dev server)
#
# Set USE_LOCAL_DB=true to use the local Docker Postgres:
USE_LOCAL_DB=true

# ======================
# PRODUCTION / NEON (only needed for deployment)
# ======================
# Connection string from Neon dashboard or Vercel Postgres integration
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Admin password for /pending page
ADMIN_PASSWORD=local-dev-password

# Admin token for URL-based auto-login (generate with: openssl rand -hex 32)
ADMIN_TOKEN=local-dev-token

# Telegram notifications for new submissions (optional, not needed for local dev)
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# TELEGRAM_CHAT_ID=your-telegram-chat-id
